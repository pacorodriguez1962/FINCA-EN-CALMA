    <div style="display:inline-block;border:1px solid rgba(200,150,62,0.35);padding:6px 18px;margin-bottom:28px;font-size:10px;letter-spacing:3px;color:var(--gold-light);text-transform:uppercase;">
      Dossier de Inversión · Proyecto Glamping · 2025
    </div>
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(68px,10vw,128px);font-weight:300;line-height:0.95;color:#fff;letter-spacing:-2px;">
      FINCA<br><strong style="font-weight:700;color:var(--gold);">en</strong> <em style="font-style:italic;font-weight:300;">Calma</em>
    </h1>
    <p style="font-family:'Cormorant Garamond',serif;font-size:clamp(17px,2.4vw,26px);font-style:italic;color:#c8bfaa;margin-top:18px;font-weight:300;">Donde el silencio se disfruta</p>
