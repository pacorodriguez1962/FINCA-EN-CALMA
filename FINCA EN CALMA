<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Finca en Calma — Dossier de Inversión Glamping</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Jost:wght@200;300;400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --gold:#C8963E;--gold-light:#E8B86D;--forest:#1B3022;
  --ink:#0D1B12;--cream:#FDF6E3;--bg:#060e05;
}
html{scroll-behavior:smooth;}
body{background:var(--bg);font-family:'Jost',sans-serif;font-weight:300;color:#e8e0d0;overflow-x:hidden;}

/* SLIDES */
.slide{width:100%;min-height:100vh;position:relative;display:flex;flex-direction:column;justify-content:center;overflow:hidden;}
.slide-full{width:100%;height:100vh;position:relative;display:flex;flex-direction:column;justify-content:center;overflow:hidden;}

/* OVERLAYS */
.bg{position:absolute;inset:0;background-size:cover;background-position:center;}
.ov-dark{position:absolute;inset:0;background:linear-gradient(160deg,rgba(6,14,5,0.90) 0%,rgba(6,14,5,0.55) 60%,rgba(6,14,5,0.78) 100%);}
.ov-left{position:absolute;inset:0;background:linear-gradient(90deg,rgba(6,14,5,0.96) 0%,rgba(6,14,5,0.6) 55%,rgba(6,14,5,0.05) 100%);}
.ov-bottom{position:absolute;inset:0;background:linear-gradient(180deg,rgba(6,14,5,0) 40%,rgba(6,14,5,0.97) 100%);}
.ov-center{position:absolute;inset:0;background:linear-gradient(180deg,rgba(6,14,5,0.55) 0%,rgba(6,14,5,0.85) 100%);}

/* LAYOUT */
.z{position:relative;z-index:2;}
.px{padding-left:clamp(28px,8vw,120px);padding-right:clamp(28px,8vw,120px);}
.py{padding-top:clamp(60px,8vh,100px);padding-bottom:clamp(60px,8vh,100px);}
.center{text-align:center;}

/* TYPOGRAPHY */
.label{font-size:11px;font-weight:500;letter-spacing:5px;text-transform:uppercase;color:var(--gold);margin-bottom:18px;display:block;}
.headline{font-family:'Cormorant Garamond',serif;font-weight:600;line-height:1.05;color:#fff;}
.body-text{font-size:15px;color:#a89f90;line-height:1.75;font-weight:300;}
.divider{width:56px;height:1px;background:var(--gold);margin:18px 0;}
.divider-c{margin:18px auto;}

/* FOOTER STRIP */
.strip{position:absolute;bottom:0;left:0;right:0;padding:16px clamp(28px,8vw,120px);display:flex;justify-content:space-between;border-top:1px solid rgba(200,150,62,0.1);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(200,150,62,0.3);z-index:5;}

/* SCROLL HINT */
.scroll-hint{position:absolute;bottom:38px;left:50%;transform:translateX(-50%);z-index:5;display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0.45;animation:float 2.5s ease-in-out infinite;}
.scroll-hint span{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#c8bfaa;}
.scroll-line{width:1px;height:38px;background:linear-gradient(180deg,rgba(200,150,62,0.6),transparent);}
@keyframes float{0%,100%{transform:translateX(-50%) translateY(0);}50%{transform:translateX(-50%) translateY(6px);}}

/* HERITAGE BAND */
.band{background:var(--gold);padding:13px clamp(28px,8vw,120px);display:flex;align-items:center;justify-content:center;gap:36px;flex-wrap:wrap;}
.band-item{font-size:10px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--forest);}
.band-dot{width:4px;height:4px;background:var(--forest);border-radius:50%;opacity:0.35;}

/* HISTORIA LAYOUT */
.historia{display:grid;grid-template-columns:0.9fr 1.1fr;}
.historia-img{position:relative;overflow:hidden;min-height:100vh;}
.historia-img img{width:100%;height:100%;object-fit:cover;display:block;}
.historia-img::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent 55%,var(--bg) 100%);}
.historia-txt{padding:clamp(50px,8vh,100px) clamp(36px,5vw,70px);display:flex;flex-direction:column;justify-content:center;}

/* BADGE */
.badge{display:inline-block;border:1px solid var(--gold);color:var(--gold);font-size:10px;letter-spacing:4px;text-transform:uppercase;padding:6px 16px;margin-bottom:28px;width:fit-content;}

/* CARDS */
.card{background:rgba(255,255,255,0.03);border:1px solid rgba(200,150,62,0.15);padding:30px 26px;position:relative;}
.card::before{content:'';position:absolute;top:0;left:0;width:3px;height:36px;background:var(--gold);}
.card-title{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:600;color:#e8e0d0;margin-bottom:8px;}

/* GRID HELPERS */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:start;}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;}

/* EXPERIENCE CARDS */
.exp{border:1px solid rgba(200,150,62,0.12);padding:36px 28px;transition:border-color .3s;}
.exp:hover{border-color:rgba(200,150,62,0.4);}
.exp-icon{font-size:26px;margin-bottom:18px;}
.exp-title{font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:600;color:#e8e0d0;margin-bottom:10px;}

/* METRICS */
.metric-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(200,150,62,0.1);}
.metric{background:var(--bg);padding:38px 26px;text-align:center;}
.metric-num{font-family:'Cormorant Garamond',serif;font-size:50px;font-weight:300;color:var(--gold);line-height:1;}
.metric-lbl{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#5a5248;margin-top:8px;}
.metric-sub{font-size:12px;color:#4a4440;margin-top:4px;}

/* ROI */
.roi-row{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:rgba(200,150,62,0.07);}
.roi{background:var(--bg);padding:36px 28px;}
.roi-marca{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:14px;}
.roi-num{font-family:'Cormorant Garamond',serif;font-size:34px;font-weight:300;color:#e8e0d0;line-height:1;}
.roi-lbl{font-size:12px;color:#4a4440;margin-top:4px;margin-bottom:18px;}
.roi-bar-bg{height:3px;background:rgba(255,255,255,0.06);margin-bottom:6px;}
.roi-bar{height:3px;background:var(--gold);}
.roi-pct{font-size:12px;color:var(--gold-light);}

/* BUDGET TABLE */
.btable{width:100%;border-collapse:collapse;}
.btable th{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:500;border-bottom:1px solid rgba(200,150,62,0.25);padding:11px 14px;text-align:left;}
.btable td{padding:13px 14px;border-bottom:1px solid rgba(255,255,255,0.04);font-size:14px;color:#a89f90;}
.btable tr:hover td{background:rgba(200,150,62,0.03);}
.btable .sec td{color:var(--gold-light);font-size:10px;letter-spacing:2px;text-transform:uppercase;padding-top:22px;}
.btable .tot td{color:#e8e0d0;font-weight:500;border-top:1px solid rgba(200,150,62,0.3);border-bottom:none;}

/* TIMELINE */
.tl-item{display:grid;grid-template-columns:70px 1px 1fr;gap:0 28px;padding-bottom:36px;}
.tl-num{font-family:'Cormorant Garamond',serif;font-size:46px;font-weight:300;color:rgba(200,150,62,0.18);text-align:right;line-height:1;}
.tl-line{background:linear-gradient(180deg,var(--gold) 0%,rgba(200,150,62,0.08) 100%);}
.tl-c{padding-top:6px;}
.tl-phase{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:5px;}
.tl-title{font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:600;color:#e8e0d0;margin-bottom:7px;}
.tl-desc{font-size:13px;color:#6a6258;line-height:1.6;}
.tl-time{font-size:11px;color:rgba(200,150,62,0.55);margin-top:7px;}

/* GALERÍA MOSAICO */
.gal-caption{position:absolute;bottom:0;left:0;right:0;padding:16px 20px;background:linear-gradient(transparent,rgba(6,14,5,0.88));}
.gal-season{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:3px;}
.gal-title{font-family:'Cormorant Garamond',serif;font-size:17px;color:#fff;}

/* CONTACT */
.cbox{border:1px solid rgba(200,150,62,0.22);padding:48px 56px;max-width:680px;margin:0 auto;text-align:center;position:relative;}
.cbox::before,.cbox::after{content:'';position:absolute;width:18px;height:18px;border-color:var(--gold);border-style:solid;}
.cbox::before{top:-1px;left:-1px;border-width:2px 0 0 2px;}
.cbox::after{bottom:-1px;right:-1px;border-width:0 2px 2px 0;}
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:32px;text-align:left;}
.clabel{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);}
.cval{font-size:15px;color:#c8bfaa;margin-top:3px;}

/* TARIFA ROWS */
.trow{padding:18px 24px;display:flex;justify-content:space-between;align-items:center;}

/* RESPONSIVE */
@media(max-width:900px){
  .historia{grid-template-columns:1fr;}
  .historia-img{min-height:50vh;}
  .historia-img::after{background:linear-gradient(180deg,transparent 60%,var(--bg) 100%);}
  .g2{grid-template-columns:1fr;}
  .metric-row{grid-template-columns:1fr 1fr;}
  .roi-row{grid-template-columns:1fr;}
  .g3{grid-template-columns:1fr;}
  .cgrid{grid-template-columns:1fr;}
  .band{gap:16px;}
}
@media(max-width:580px){
  .metric-row{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- ══════ SLIDE 1: PORTADA ══════ -->
<section class="slide-full">
  <div class="bg" style="background-image:url('21.jpg');"></div>
